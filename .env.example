# Copy to `.env` (gitignored) and fill in the keys you have. Real shell env vars override these.
# The untell CLIs auto-load this file at startup. Only set the checkers you actually use.

# --- Commercial AI-detector checkers (untell-verify / --tier commercial) ---
GPTZERO_API_KEY=
ORIGINALITY_API_KEY=
WINSTON_API_KEY=
SAPLING_API_KEY=
ZEROGPT_API_KEY=
# Copyleaks needs both (2-step login). Sandbox mode (free mock) still requires these.
COPYLEAKS_EMAIL=
COPYLEAKS_API_KEY=

# --- Hosted-LLM rewriter (untell-loop, optional) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
